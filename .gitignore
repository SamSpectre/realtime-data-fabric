# Data-to-AI Mastery - Git Ignore

# ===================
# Environment & Secrets
# ===================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ===================
# Python
# ===================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# ===================
# Jupyter
# ===================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ===================
# IDE
# ===================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ===================
# Large Data Files
# ===================
# Keep small datasets, ignore large ones
data/raw/*.parquet
data/raw/*.csv
!data/raw/.gitkeep
data/processed/
*.db
*.sqlite
*.duckdb

# Specific large files
*.tar.gz
*.zip
*.7z

# ===================
# MLflow
# ===================
mlruns/
mlflow.db
mlartifacts/

# ===================
# Build & Dist
# ===================
build/
dist/
*.egg-info/
*.egg

# ===================
# Testing
# ===================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ===================
# OS Files
# ===================
.DS_Store
Thumbs.db
desktop.ini

# ===================
# Logs
# ===================
*.log
logs/

# ===================
