# Data-to-AI Mastery - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ===================
# LLM API Keys
# ===================
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ===================
# LangSmith (Observability)
# ===================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=data-ai-mastery

# ===================
# PostgreSQL (Project 1)
# ===================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taxi_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ===================
# Snowflake (Project 4)
# ===================
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_user_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=PUBLIC

# ===================
# Databricks (Project 3 & 5)
# ===================
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here

# ===================
# MLflow
# ===================
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# For Databricks MLflow:
# MLFLOW_TRACKING_URI=databricks

# ===================
# Data APIs (Project 2)
# ===================
SEC_EDGAR_USER_AGENT=your_email@example.com
ALPHA_VANTAGE_API_KEY=your_key_here
